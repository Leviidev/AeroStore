#include "../Build.xcconfig"

// Use HOST_BUNDLE_IDENTIFIER (not PRODUCT_BUNDLE_IDENTIFIER): the latter can be folded too early relative to -xcconfig merge, breaking SideStore-bundle builds.
PRODUCT_BUNDLE_IDENTIFIER[config=Debug] = $(HOST_BUNDLE_IDENTIFIER).AltWidget
PRODUCT_BUNDLE_IDENTIFIER[config=Release] = $(HOST_BUNDLE_IDENTIFIER).AltWidget
