#include "../Build.xcconfig"

// Must be prefixed by the host app bundle ID (e.g. SideStore-bundle IPA merges Build.SideStoreBundleID.xcconfig).
PRODUCT_BUNDLE_IDENTIFIER[config=Debug] = $(PRODUCT_BUNDLE_IDENTIFIER).AltWidget
PRODUCT_BUNDLE_IDENTIFIER[config=Release] = $(PRODUCT_BUNDLE_IDENTIFIER).AltWidget
